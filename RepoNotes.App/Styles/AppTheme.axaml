<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <SolidColorBrush x:Key="Brush.AppBackground" Color="#0B111A" />
    <SolidColorBrush x:Key="Brush.TopBar" Color="#0A0F17" />
    <SolidColorBrush x:Key="Brush.Sidebar" Color="#0D1520" />
    <SolidColorBrush x:Key="Brush.Panel" Color="#101823" />
    <SolidColorBrush x:Key="Brush.Editor" Color="#0B1018" />
    <SolidColorBrush x:Key="Brush.Border" Color="#223041" />
    <SolidColorBrush x:Key="Brush.Divider" Color="#1F2937" />
    <SolidColorBrush x:Key="Brush.Text" Color="#E5E7EB" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#9CA3AF" />
    <SolidColorBrush x:Key="Brush.TextWeak" Color="#6B7280" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#6366F1" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#4F46E5" />
    <SolidColorBrush x:Key="Brush.StatusSaved" Color="#22C55E" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FBBF24" />
    <SolidColorBrush x:Key="Brush.PreviewInlineCode" Color="#C4B5FD" />
    <SolidColorBrush x:Key="Brush.PreviewLink" Color="#93C5FD" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource Brush.AppBackground}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource Brush.Panel}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    <Setter Property="Background" Value="#151F2C" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#1B2736" />
    <Setter Property="BorderBrush" Value="#34445A" />
  </Style>

  <Style Selector="Button.repository-card">
    <Setter Property="Background" Value="#101823" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.repository-card:pointerover">
    <Setter Property="Background" Value="#142033" />
    <Setter Property="BorderBrush" Value="#34445A" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{StaticResource Brush.AccentHover}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentHover}" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
  </Style>

  <Style Selector="Button.context-action">
    <Setter Property="Height" Value="26" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="#121C29" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
  </Style>

  <Style Selector="Button.note-tab">
    <Setter Property="Height" Value="38" />
    <Setter Property="Padding" Value="8,0,22,0" />
    <Setter Property="CornerRadius" Value="7,7,0,0" />
    <Setter Property="Background" Value="#0F1824" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Divider}" />
    <Setter Property="BorderThickness" Value="1,0,1,1" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
  </Style>

  <Style Selector="Button.note-tab:pointerover">
    <Setter Property="Background" Value="#152234" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Button.note-tab.active">
    <Setter Property="Background" Value="{StaticResource Brush.Panel}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1,0,1,0" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Button.tab-close">
    <Setter Property="Width" Value="20" />
    <Setter Property="Height" Value="20" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextWeak}" />
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,0,3,0" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="Button.tab-close:pointerover">
    <Setter Property="Background" Value="#1F2937" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="GridSplitter.split-divider">
    <Setter Property="Background" Value="{StaticResource Brush.Divider}" />
    <Setter Property="Opacity" Value="0.65" />
    <Setter Property="Margin" Value="1,0" />
  </Style>

  <Style Selector="GridSplitter.split-divider:pointerover">
    <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
    <Setter Property="Opacity" Value="0.85" />
  </Style>

  <Style Selector="Border.command-palette">
    <Setter Property="Background" Value="#101823" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="TextBox.command-palette-search">
    <Setter Property="Height" Value="38" />
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="#0B1018" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="Button.command-palette-item">
    <Setter Property="MinHeight" Value="48" />
    <Setter Property="Padding" Value="10,7" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.command-palette-item:pointerover">
    <Setter Property="Background" Value="#17213A" />
  </Style>

  <Style Selector="Button.command-palette-item.selected">
    <Setter Property="Background" Value="#24315D" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
  </Style>

  <Style Selector="Button.mode-toggle">
    <Setter Property="Height" Value="26" />
    <Setter Property="MinWidth" Value="62" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="#0D141E" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
  </Style>

  <Style Selector="Button.mode-toggle:pointerover">
    <Setter Property="Background" Value="#17213A" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Button.mode-toggle.active">
    <Setter Property="Background" Value="#24315D" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
  </Style>

  <Style Selector="Border.window-bar">
    <Setter Property="Background" Value="{StaticResource Brush.TopBar}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Divider}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Button.window-control">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.window-control:pointerover">
    <Setter Property="Background" Value="#17213A" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Button.window-control.close:pointerover">
    <Setter Property="Background" Value="#991B1B" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.sidebar-action">
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="5,0" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
  </Style>

  <Style Selector="Button.sidebar-action:pointerover">
    <Setter Property="Background" Value="#1B2736" />
    <Setter Property="BorderBrush" Value="#34445A" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Border.collapsed-rail">
    <Setter Property="Background" Value="{StaticResource Brush.Sidebar}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="0,0,0,0" />
  </Style>

  <Style Selector="Button.panel-toggle">
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.panel-toggle:pointerover">
    <Setter Property="Background" Value="#1B2736" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    <Setter Property="Background" Value="{StaticResource Brush.Editor}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="SelectionBrush" Value="{StaticResource Brush.Accent}" />
  </Style>

  <Style Selector="TextBox.search">
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="32,5,58,5" />
    <Setter Property="Background" Value="#0D141E" />
  </Style>

  <Style Selector="Button.search-clear">
    <Setter Property="Width" Value="20" />
    <Setter Property="Height" Value="20" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="#111827" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextWeak}" />
  </Style>

  <Style Selector="Button.search-clear:pointerover">
    <Setter Property="Background" Value="#1B2736" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="TextBox.metadata-field">
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="#0D141E" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
  </Style>

  <Style Selector="ComboBox.template-picker">
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="Background" Value="#0D141E" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ComboBox.template-picker:pointerover">
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="#34445A" />
  </Style>

  <Style Selector="ComboBox.metadata-picker">
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="Background" Value="#0D141E" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="ComboBox.metadata-picker:pointerover">
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="#34445A" />
  </Style>

  <Style Selector="ComboBox.trash-picker">
    <Setter Property="Height" Value="30" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="Background" Value="#0D141E" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="ComboBox.trash-picker:pointerover">
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="#34445A" />
  </Style>

  <Style Selector="TreeView">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="TreeViewItem">
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="3,1" />
    <Setter Property="CornerRadius" Value="7" />
  </Style>

  <Style Selector="TreeViewItem:selected">
    <Setter Property="Background" Value="#24315D" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Border.search-empty">
    <Setter Property="Background" Value="#0D141EE6" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabItem">
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    <Setter Property="Padding" Value="18,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
  </Style>

  <Style Selector="Border.status-bar">
    <Setter Property="Background" Value="{StaticResource Brush.TopBar}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Divider}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
  </Style>

  <Style Selector="Border.tag-chip">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="6,2" />
  </Style>

  <Style Selector="Button.tag-chip">
    <Setter Property="Height" Value="24" />
    <Setter Property="Padding" Value="6,0" />
    <Setter Property="Margin" Value="0,0,5,5" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="#24203E" />
    <Setter Property="BorderBrush" Value="#352B68" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.tag-chip:pointerover">
    <Setter Property="Background" Value="#30275A" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
  </Style>

  <Style Selector="Button.tag-clear">
    <Setter Property="Height" Value="20" />
    <Setter Property="Padding" Value="6,0" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextWeak}" />
  </Style>

  <Style Selector="Button.internal-link">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="Margin" Value="0,0,0,5" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="#111B28" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.internal-link:pointerover">
    <Setter Property="Background" Value="#17213A" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
  </Style>
</Styles>
